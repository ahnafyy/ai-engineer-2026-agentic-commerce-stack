# Copy this file to `.env` and fill in your token, then run `docker-compose up --build`.
#
# GITHUB_TOKEN: a GitHub Personal Access Token with the `read:packages` scope.
# It is used to call GPT-4o through GitHub AI Models (https://models.inference.ai.azure.com).
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_with_read_packages_scope
