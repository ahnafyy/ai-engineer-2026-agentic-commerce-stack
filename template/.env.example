# Copy this file to `.env` and fill in your key, then run `docker-compose up --build`.
#
# CEREBRAS_API_KEY: a Cerebras API key. It is used to call the model through
# Cerebras inference (https://api.cerebras.ai/v1). Create one at https://cloud.cerebras.ai
# CEREBRAS_MODEL: optional, defaults to gpt-oss-120b.
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=gpt-oss-120b
